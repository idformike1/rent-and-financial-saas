generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ----------------------------------------------------------------------------
// Operational Entities
// ----------------------------------------------------------------------------

enum MaintenanceStatus {
  OPERATIONAL
  UNDER_REPAIR
  DECOMMISSIONED
}

model Property {
  id             String        @id @default(uuid())
  organizationId String
  name           String        // e.g., "North Complex"
  address        String
  createdAt      DateTime      @default(now())
  
  organization   Organization  @relation(fields: [organizationId], references: [id])
  units          Unit[]
  ledgerEntries  LedgerEntry[]

  @@index([organizationId])
}

model Unit {
  id                String            @id @default(uuid())
  propertyId        String
  unitNumber        String
  type              String            // e.g., "Apartment", "Parking", "Storage"
  category          String            @default("FLAT") // e.g., "FLAT", "STORE", "SHUTTER", "PARKING"
  maintenanceStatus MaintenanceStatus @default(OPERATIONAL)
  
  property          Property          @relation(fields: [propertyId], references: [id])
  leases            Lease[]
}

model Tenant {
  id             String        @id @default(uuid())
  organizationId String
  name           String
  email          String?       // Deduplication candidate
  phone          String?       // Deduplication candidate
  nationalId     String?       // Deduplication candidate
  isDeleted      Boolean       @default(false)
  
  organization   Organization  @relation(fields: [organizationId], references: [id])
  leases         Lease[]
  charges        Charge[]

  @@index([organizationId])
}

model Lease {
  id             String   @id @default(uuid())
  tenantId       String
  unitId         String
  isPrimary      Boolean  @default(false)
  rentAmount     Decimal
  depositAmount  Decimal  @default(0.00)
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean  @default(true)
  
  unit           Unit     @relation(fields: [unitId], references: [id])
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  charges        Charge[]
}

// ----------------------------------------------------------------------------
// Financial Entities
// ----------------------------------------------------------------------------

enum ExpenseScope {
  PERSONAL
  HOME
  PROPERTY
}

model ExpenseCategory {
  id             String            @id @default(uuid())
  organizationId String
  name           String
  scope          ExpenseScope
  parentId       String?
  
  organization   Organization      @relation(fields: [organizationId], references: [id])
  parent         ExpenseCategory?  @relation("SubCategories", fields: [parentId], references: [id])
  children       ExpenseCategory[] @relation("SubCategories")
  entries        LedgerEntry[]

  @@unique([name, scope, parentId, organizationId])
  @@index([organizationId])
}

enum ChargeType {
  RENT
  WATER_SUBMETER
  ELEC_SUBMETER
  LATE_FEE
  CREDIT
}

enum AccountCategory {
  ASSET       // Cash, Bank Checking, Savings
  INCOME      // Rental Revenue, Utility Recovery
  EXPENSE     // Master Water Bill, Master Elec Bill, Personal Draw
}

model Charge {
  id          String     @id @default(uuid())
  tenantId    String
  leaseId     String     
  type        ChargeType
  amount      Decimal
  amountPaid  Decimal    @default(0.00)
  dueDate     DateTime
  isFullyPaid Boolean    @default(false)

  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  lease       Lease      @relation(fields: [leaseId], references: [id])
}

model Account {
  id          String          @id @default(uuid())
  name        String          
  category    AccountCategory
  entries     LedgerEntry[]
}

enum PaymentMode {
  CASH
  BANK
}

model LedgerEntry {
  id                String           @id @default(uuid())
  organizationId    String
  transactionId     String   
  accountId         String
  amount            Decimal  
  date              DateTime         @default(now()) // System timestamp
  transactionDate   DateTime         @default(now()) // Actual payment date
  description       String
  paymentMode       PaymentMode      @default(CASH)
  referenceText     String?
  
  // Unified Wealth Ledger Upgrades
  expenseCategoryId String?
  propertyId        String?
  payee             String?
  receiptUrl        String?

  organization      Organization     @relation(fields: [organizationId], references: [id])
  account           Account          @relation(fields: [accountId], references: [id])
  expenseCategory   ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id])
  property          Property?        @relation(fields: [propertyId], references: [id])

  @@index([organizationId])
  @@index([transactionId])
}

// ----------------------------------------------------------------------------
// Audit Trail Entities
// ----------------------------------------------------------------------------

enum AuditActionType {
  WAIVE_OFF
  MANUAL_CREDIT
  VOID_PAYMENT
  MAINTENANCE_DECOMMISSION
}

model AuditLog {
  id             String          @id @default(uuid())
  organizationId String
  timestamp      DateTime        @default(now())
  managerId      String          
  actionType     AuditActionType 
  targetId       String          
  amountContext  Decimal         
  reasonText     String          

  @@index([organizationId])
}

// ----------------------------------------------------------------------------
// Multi-Tenancy (B2B SaaS Foundation)
// ----------------------------------------------------------------------------

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  users             User[]
  properties        Property[]
  tenants           Tenant[]
  expenseCategories ExpenseCategory[]
  ledgerEntries     LedgerEntry[]
}

model User {
  id             String       @id @default(uuid())
  organizationId String
  email          String       @unique
  name           String?
  passwordHash   String
  role           UserRole     @default(MANAGER)
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

enum UserRole {
  OWNER
  MANAGER
  ADMIN
}
