generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Property {
  id             String        @id @default(uuid())
  organizationId String
  name           String
  address        String
  createdAt      DateTime      @default(now())
  deletedAt      DateTime?
  ledgerEntries  LedgerEntry[]
  organization   Organization  @relation(fields: [organizationId], references: [id])
  units          Unit[]

  @@index([organizationId])
}

model Unit {
  id                String            @id @default(uuid())
  organizationId    String
  propertyId        String
  unitNumber        String
  type              String
  category          String            @default("FLAT")
  maintenanceStatus MaintenanceStatus @default(OPERATIONAL)
  marketRent        Decimal           @default(0.00)
  deletedAt         DateTime?
  leases            Lease[]
  organization      Organization      @relation(fields: [organizationId], references: [id])
  property          Property          @relation(fields: [propertyId], references: [id])
  meterReadings     MeterReading[]

  @@index([organizationId])
}

model MeterReading {
  id     String   @id @default(uuid())
  unitId String
  unit   Unit     @relation(fields: [unitId], references: [id])
  value  Float // The reading (e.g., 322)
  date   DateTime @default(now())
  type   String // 'ELECTRIC' or 'WATER'
}

model Tenant {
  id             String        @id @default(uuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  nationalId     String?
  isDeleted      Boolean       @default(false)
  charges        Charge[]
  leases         Lease[]
  ledgerEntries  LedgerEntry[]
  organization   Organization  @relation(fields: [organizationId], references: [id])
}

model Lease {
  id             String       @id @default(uuid())
  organizationId String
  tenantId       String
  unitId         String
  isPrimary      Boolean      @default(false)
  rentAmount     Decimal
  depositAmount  Decimal      @default(0.00)
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean      @default(true)
  deletedAt      DateTime?
  charges        Charge[]
  organization   Organization @relation(fields: [organizationId], references: [id])
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  unit           Unit         @relation(fields: [unitId], references: [id])

  @@index([organizationId])
}

model FinancialLedger {
  id             String            @id @default(uuid())
  organizationId String
  name           String
  class          String            @default("EXPENSE")
  createdAt      DateTime          @default(now())
  categories     ExpenseCategory[]
  organization   Organization      @relation(fields: [organizationId], references: [id])

  @@unique([name, organizationId])
}

model ExpenseCategory {
  id             String            @id @default(uuid())
  organizationId String
  name           String
  ledgerId       String
  parentId       String?
  isPersonal     Boolean           @default(false)
  isArchived     Boolean           @default(false)
  ledger         FinancialLedger   @relation(fields: [ledgerId], references: [id])
  organization   Organization      @relation(fields: [organizationId], references: [id])
  parent         ExpenseCategory?  @relation("SubCategories", fields: [parentId], references: [id])
  children       ExpenseCategory[] @relation("SubCategories")
  entries        LedgerEntry[]

  @@unique([name, ledgerId, parentId, organizationId])
}

model Charge {
  id             String        @id @default(uuid())
  organizationId String
  tenantId       String
  leaseId        String
  type           ChargeType
  amount         Decimal
  amountPaid     Decimal       @default(0.00)
  dueDate        DateTime
  servicePeriod  String? // e.g. "2026-01"
  isFullyPaid    Boolean       @default(false)
  deletedAt      DateTime?
  lease          Lease         @relation(fields: [leaseId], references: [id])
  organization   Organization  @relation(fields: [organizationId], references: [id])
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  ledgerEntries  LedgerEntry[]

  @@index([organizationId, servicePeriod])
  @@index([organizationId])
}

model Account {
  id             String          @id @default(uuid())
  organizationId String
  name           String
  category       AccountCategory
  parentId       String?
  isSystem       Boolean         @default(false)
  deletedAt      DateTime?
  organization   Organization    @relation(fields: [organizationId], references: [id])
  parent         Account?        @relation("SubAccounts", fields: [parentId], references: [id])
  children       Account[]       @relation("SubAccounts")
  entries        LedgerEntry[]

  @@index([organizationId])
}

model LedgerEntry {
  id                String           @id @default(uuid())
  organizationId    String
  transactionId     String
  accountId         String?
  type              EntryType
  amount            Decimal
  date              DateTime         @default(now())
  transactionDate   DateTime         @default(now())
  description       String
  paymentMode       PaymentMode      @default(CASH)
  referenceText     String?
  status            EntryStatus      @default(ACTIVE)
  isCleared         Boolean          @default(false)
  clearedAt         DateTime?
  expenseCategoryId String?
  wealthAccountId   String?
  incomeSourceId    String?
  propertyId        String?
  tenantId          String?          @map("tenant_id")
  payee             String?
  receiptUrl        String?
  chargeId          String?
  charge            Charge?          @relation(fields: [chargeId], references: [id])
  account           Account?         @relation(fields: [accountId], references: [id])
  wealthAccount     WealthAccount?   @relation(fields: [wealthAccountId], references: [id])
  incomeSource      IncomeSource?    @relation(fields: [incomeSourceId], references: [id])
  expenseCategory   ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id])
  organization      Organization     @relation(fields: [organizationId], references: [id])
  property          Property?        @relation(fields: [propertyId], references: [id])
  tenant            Tenant?          @relation(fields: [tenantId], references: [id])
  transaction       Transaction      @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  deletedAt         DateTime?

  @@index([chargeId])
  @@index([organizationId])
  @@index([organizationId, transactionDate])
}

model Transaction {
  id             String        @id @default(uuid())
  organizationId String
  idempotencyKey String?       @unique
  description    String
  date           DateTime      @default(now())
  deletedAt      DateTime?
  entries        LedgerEntry[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
}

enum EntryType {
  DEBIT
  CREDIT
}

model AuditLog {
  id             String        @id @default(uuid())
  action         String
  entityType     String
  entityId       String
  targetName     String?
  metadata       Json?
  userId         String
  organizationId String?
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user           User          @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt(sort: Desc)])
}

model Organization {
  id                  String               @id @default(uuid())
  name                String
  createdAt           DateTime             @default(now())
  deletedAt           DateTime?
  accounts            Account[]
  auditLogs           AuditLog[]
  categorizationRules CategorizationRule[]
  charges             Charge[]
  expenseCategories   ExpenseCategory[]
  financialLedgers    FinancialLedger[]
  idempotencyRecords  IdempotencyRecord[]
  leases              Lease[]
  ledgerEntries       LedgerEntry[]
  properties          Property[]
  reportSnapshots     ReportSnapshot[]
  tenants             Tenant[]
  units               Unit[]
  users               User[]
  invitations         Invitation[]
  members             OrganizationMember[]
  wealthAccounts      WealthAccount[]
  incomeSources       IncomeSource[]
  isSuspended         Boolean              @default(false)
  settings            SystemSettings?
}

model SystemSettings {
  id                String       @id @default(uuid())
  organizationId    String       @unique
  electricTariff    Decimal      @default(0.15)
  waterTariff       Decimal      @default(0.05)
  lateFeePercentage Decimal      @default(5.0)
  gracePeriodDays   Int          @default(5)
  updatedAt         DateTime     @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id])
}

model WealthAccount {
  id             String          @id @default(uuid())
  organizationId String
  name           String
  category       AccountCategory @default(ASSET)
  isArchived     Boolean         @default(false)
  deletedAt      DateTime?
  organization   Organization    @relation(fields: [organizationId], references: [id])
  ledgerEntries  LedgerEntry[]

  @@index([organizationId])
}

model IncomeSource {
  id             String        @id @default(uuid())
  organizationId String
  name           String
  isArchived     Boolean       @default(false)
  deletedAt      DateTime?
  organization   Organization  @relation(fields: [organizationId], references: [id])
  ledgerEntries  LedgerEntry[]

  @@index([organizationId])
}

model OrganizationMember {
  userId          String
  organizationId  String
  role            String       @default("MANAGER")
  status          String       @default("ACTIVE")
  canAccessRent   Boolean      @default(true)
  canAccessWealth Boolean      @default(true)
  createdAt       DateTime     @default(now())
  user            User         @relation(fields: [userId], references: [id])
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@id([userId, organizationId])
}

model ReportSnapshot {
  id             String       @id @default(uuid())
  urlToken       String       @unique
  payload        Json
  expiresAt      DateTime
  organizationId String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model CategorizationRule {
  id             String       @id @default(uuid())
  keyword        String
  mappedCategory String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model User {
  id                     String               @id @default(uuid())
  email                  String               @unique
  passwordHash           String               @map("password")
  name                   String?
  firstName              String?
  lastName               String?
  role                   String               @default("MANAGER") // Supported: OWNER, ADMIN, MANAGER, VIEWER
  organizationId         String?
  isActive               Boolean              @default(true)
  isSystemAdmin          Boolean              @default(false)
  accountStatus          String               @default("ACTIVE")
  canEdit                Boolean              @default(true)
  requiresPasswordChange Boolean              @default(false)
  createdAt              DateTime             @default(now())
  deletedAt              DateTime?
  auditLogs              AuditLog[]
  organization           Organization?        @relation(fields: [organizationId], references: [id])
  memberships            OrganizationMember[]

  @@index([organizationId])
}

model IdempotencyRecord {
  id             String       @id @default(uuid())
  key            String       @unique
  result         Json?
  createdAt      DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([key, organizationId])
}

model Invitation {
  id             String           @id @default(uuid())
  token          String           @unique
  email          String
  firstName      String?
  lastName       String?
  role           String // Supported: OWNER, ADMIN, MANAGER, VIEWER
  organizationId String
  status         InvitationStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
}

enum MaintenanceStatus {
  OPERATIONAL
  UNDER_REPAIR
  DECOMMISSIONED
}

enum ChargeType {
  RENT
  SECURITY_DEPOSIT
  WATER_SUBMETER
  ELEC_SUBMETER
  LATE_FEE
  CREDIT
}

enum AccountCategory {
  ASSET
  INCOME
  EXPENSE
  LIABILITY
  EQUITY
}

enum PaymentMode {
  CASH
  BANK
}

enum EntryStatus {
  ACTIVE
  VOIDED
}
