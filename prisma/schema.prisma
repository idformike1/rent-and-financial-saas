generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Property {
  id             String        @id @default(uuid())
  organizationId String
  name           String
  address        String
  createdAt      DateTime      @default(now())
  ledgerEntries  LedgerEntry[]
  organization   Organization  @relation(fields: [organizationId], references: [id])
  units          Unit[]
}

model Unit {
  id                String            @id @default(uuid())
  organizationId    String
  propertyId        String
  unitNumber        String
  type              String
  category          String            @default("FLAT")
  maintenanceStatus MaintenanceStatus @default(OPERATIONAL)
  marketRent        Decimal           @default(0.00)
  leases            Lease[]
  organization      Organization      @relation(fields: [organizationId], references: [id])
  property          Property          @relation(fields: [propertyId], references: [id])
}

model Tenant {
  id             String        @id @default(uuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  nationalId     String?
  isDeleted      Boolean       @default(false)
  charges        Charge[]
  leases         Lease[]
  ledgerEntries  LedgerEntry[]
  organization   Organization  @relation(fields: [organizationId], references: [id])
}

model Lease {
  id             String       @id @default(uuid())
  organizationId String
  tenantId       String
  unitId         String
  isPrimary      Boolean      @default(false)
  rentAmount     Decimal
  depositAmount  Decimal      @default(0.00)
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean      @default(true)
  charges        Charge[]
  organization   Organization @relation(fields: [organizationId], references: [id])
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  unit           Unit         @relation(fields: [unitId], references: [id])
}

model FinancialLedger {
  id             String            @id @default(uuid())
  organizationId String
  name           String
  class          String            @default("EXPENSE")
  createdAt      DateTime          @default(now())
  categories     ExpenseCategory[]
  organization   Organization      @relation(fields: [organizationId], references: [id])

  @@unique([name, organizationId])
}

model ExpenseCategory {
  id             String            @id @default(uuid())
  organizationId String
  name           String
  ledgerId       String
  parentId       String?
  isPersonal     Boolean           @default(false)
  ledger         FinancialLedger   @relation(fields: [ledgerId], references: [id])
  organization   Organization      @relation(fields: [organizationId], references: [id])
  parent         ExpenseCategory?  @relation("SubCategories", fields: [parentId], references: [id])
  children       ExpenseCategory[] @relation("SubCategories")
  entries        LedgerEntry[]

  @@unique([name, ledgerId, parentId, organizationId])
}

model Charge {
  id             String       @id @default(uuid())
  organizationId String
  tenantId       String
  leaseId        String
  type           ChargeType
  amount         Decimal
  amountPaid     Decimal      @default(0.00)
  dueDate        DateTime
  isFullyPaid    Boolean      @default(false)
  lease          Lease        @relation(fields: [leaseId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
}

model Account {
  id             String          @id @default(uuid())
  organizationId String
  name           String
  category       AccountCategory
  organization   Organization    @relation(fields: [organizationId], references: [id])
  entries        LedgerEntry[]
}

model LedgerEntry {
  id                String           @id @default(uuid())
  organizationId    String
  transactionId     String
  accountId         String
  amount            Decimal
  date              DateTime         @default(now())
  transactionDate   DateTime         @default(now())
  description       String
  paymentMode       PaymentMode      @default(CASH)
  referenceText     String?
  status            EntryStatus      @default(ACTIVE)
  isCleared         Boolean          @default(false)
  clearedAt         DateTime?
  expenseCategoryId String?
  propertyId        String?
  tenantId          String?          @map("tenant_id")
  payee             String?
  receiptUrl        String?
  account           Account          @relation(fields: [accountId], references: [id])
  expenseCategory   ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id])
  organization      Organization     @relation(fields: [organizationId], references: [id])
  property          Property?        @relation(fields: [propertyId], references: [id])
  tenant            Tenant?          @relation(fields: [tenantId], references: [id])

  @@index([organizationId, transactionDate])
}

model AuditLog {
  id             String       @id @default(uuid())
  action         String
  entityType     String
  entityId       String
  metadata       Json?
  userId         String
  organizationId String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt(sort: Desc)])
}

model Organization {
  id                  String               @id @default(uuid())
  name                String
  createdAt           DateTime             @default(now())
  accounts            Account[]
  auditLogs           AuditLog[]
  categorizationRules CategorizationRule[]
  charges             Charge[]
  expenseCategories   ExpenseCategory[]
  financialLedgers    FinancialLedger[]
  idempotencyRecords  IdempotencyRecord[]
  leases              Lease[]
  ledgerEntries       LedgerEntry[]
  properties          Property[]
  reportSnapshots     ReportSnapshot[]
  tenants             Tenant[]
  units               Unit[]
  users               User[]
  invitations         Invitation[]
}

model ReportSnapshot {
  id             String       @id @default(uuid())
  urlToken       String       @unique
  payload        Json
  expiresAt      DateTime
  organizationId String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model CategorizationRule {
  id             String       @id @default(uuid())
  keyword        String
  mappedCategory String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  passwordHash   String       @map("password")
  name           String?
  role           String       @default("MANAGER")
  organizationId String
  isActive       Boolean      @default(true)
  canEdit        Boolean      @default(true)
  createdAt      DateTime     @default(now())
  auditLogs      AuditLog[]
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model IdempotencyRecord {
  id             String       @id @default(uuid())
  key            String       @unique
  result         Json?
  createdAt      DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([key, organizationId])
}

model Invitation {
  id             String           @id @default(uuid())
  token          String           @unique
  email          String
  role           String
  organizationId String
  status         InvitationStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
}

enum MaintenanceStatus {
  OPERATIONAL
  UNDER_REPAIR
  DECOMMISSIONED
}

enum ChargeType {
  RENT
  WATER_SUBMETER
  ELEC_SUBMETER
  LATE_FEE
  CREDIT
}

enum AccountCategory {
  ASSET
  INCOME
  EXPENSE
}

enum PaymentMode {
  CASH
  BANK
}

enum EntryStatus {
  ACTIVE
  VOIDED
}
